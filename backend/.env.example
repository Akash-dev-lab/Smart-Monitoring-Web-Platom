NODE_ENV=development
PORT=4000
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

MONGO_URI=mongodb://localhost:27017/drishya-auth

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_PREFETCH=10
RABBITMQ_MAX_RETRIES=5
RABBITMQ_RETRY_BASE_DELAY_MS=5000
QUEUE_PREFIX=DRISHYA

RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com
BRAND_NAME=Drishya
BRAND_SUPPORT_EMAIL=support@example.com
OTP_ECHO=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
REFRESH_SESSION_LOCK_SECONDS=5
FORGOT_PASSWORD_VERIFIED_TTL_SECONDS=900

OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
REGISTRATION_TTL_SECONDS=900

CORS_ORIGIN=http://localhost:5173

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
PINECONE_API_KEY=
PINECONE_INDEX_NAME=drishya
PINECONE_TEXT_FIELD=chunk_text
PINECONE_NAMESPACE_PREFIX=monitor-user
